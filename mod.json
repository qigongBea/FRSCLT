{
    // The ID of your mod. Should be unique!!
    "id": "drfc-in-too-deep-restored",
    // Displays on the main menu.
    "name": "Depths (Restored)",
    // Displays underneath the name. Optional.
    "subtitle": "",

    // The version of your mod.
    "version": "v1.0.0",
    // What version of the engine your mod was made with.
    "engineVer": "v0.10.0-dev",

    // The Deltarune chapter you'd like to base your mod off of.
    // Do keep in mind that you can control chapter-specific features
    // one by one using the config below.
    "chapter": 6,

    // The map that you start in when first starting the mod.
    "map": "chapter_select",
    "useSaves": false,

    // The party. The first character is the player.
    "party": ["kris"],
	
	
    // The inventory. Contains three darkburgers, a cell phone and a shadow crystal by default.
    "inventory": {
        "items": ["ancientsweet", "deluxedinner", "deluxedinner", "scarlixir", "flowercandy", "flowercandy"],
        "key_items": ["cell_phone", "shadowcrystal", "exitKey"],
        "storage": ["favwich", "butjuice", "glowshard", "glowshard", "javacookie"]
    },

    // Equipment for your party. Not specifying equipment defaults to the following.
    "equipment": {
        "kris": {"armor": ["tennatie", "princessrbn"], "weapon": "jingleblade"},
        "susie": {"armor": ["powerband", "waferguard"], "weapon": "absorbax"}
    },

    // Should never be true, but just in case. Restarts the entire engine when leaving the mod.
    // If you need this, you're most likely doing something wrong.
    "hardReset": false,

    "chaptername": "Chapter 6",

    // Whether the mod is hidden from the mod selection.
    "hidden": false,

    // Whether the game window's title should be set to the mod's name, when the engine is run
    // with this mod as the target mod.
    "setWindowTitle": false,

    // Config values for the engine and any libraries you may have.
    // These config values can control chapter-specific features as well.
    "config": {
        "kristal": {
            // End of config
            "enemyAuras": true,
            "speechBubble" : "depths"
        },
        "afilemenu": {
            "map": "hometown/torielhouse/kris_room",
            "configMenuOverride": true,
            "hookOverlay": true,
            "chapter_select": true,
        },
        "obscurachapters": {
            "infoProject": "Menu by Hyperboid", // If not set, defaults to "By: [Mod.info.author]"
            "infoAuthor": "DELTARUNE: Forecasted", // If not set, defaults to "[Mod.info.name] v[Mod.info.version]"
            "include_example": false, // Remove the default ch1 and ch2 (from the lib.json)
            "chapters":[
                {
                    "image": "chapters/ch1",
                    "name": "The Beginning",
                    "sound": "ui_spooky_action"
                },
                {
                    "image": "chapters/ch2",
                    "name": "A Cyber's World",
                    "sound": "deathnoise"
                },
                {
                    "image": "chapters/ch3",
                    "name": "Channel 3",
                    "unlocked": true,
                    "sound": "cardrive"
                },
                {
                    "image": "chapters/ch4",
                    "unlocked": true,
                    "name": "Snowy Side-Dish!",
                    "sound": "bluh"
                },
                {
                    "image": "chapters/ch5",
                    "name": "Dark After Dark",
                    "unlocked": true,
                    "sound": "bluh"
                },
                {
                    "image": "chapters/ch6",
                    "name": "In Too Deep",
                    "unlocked": true,
                    "sound": "bluh",
                    "index": "6",
                    "room": "bumperzone",
                    "mod": "drfc-in-too-deep-restored"
                },
                {
                    "image": "chapters/ch7",
                    "name": "Access Denied",
                    "unlocked": false,
                    "sound": "bluh",
                    "instant": true
                }
            ]
        }
    }
}